
### SPECIFY THE NUMBER OF PRODUCTION STEPS ###
variable Nprod equal 30000

### ASSIGN ATOMIC VELOCITIES ###
velocity all create ${T} 12345 dist gaussian rot yes mom yes
velocity all create 1.5 12345 dist gaussian rot yes mom yes

### SPECIFY ENSEMBLE ###
timestep ${timestep}
timestep 0.002
fix 1 all npt temp ${T} ${T} 0.1 iso ${p} ${p} 1.0
fix 1 all npt temp 1.5 ${T} 0.1 iso ${p} ${p} 1.0
fix 1 all npt temp 1.5 1.5 0.1 iso ${p} ${p} 1.0
fix 1 all npt temp 1.5 1.5 0.1 iso 1 ${p} 1.0
fix 1 all npt temp 1.5 1.5 0.1 iso 1 1 1.0

### THERMODYNAMIC OUTPUT CONTROL ###
thermo_style custom time pe ke etotal temp press
thermo 1

### RECORD TRAJECTORY ###
dump traj all custom 1000 traj.dump id x y z

### SPECIFY TIMESTEP ###
variable n_steps equal floor(50/${timestep})
variable n_steps equal floor(50/0.002)
timestep ${timestep}
timestep 0.002

### RUN SIMULATION TO MELT CRYSTAL ###
run ${n_steps}
run 25000
